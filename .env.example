# =============================================================================
# .env.example — API Anahtarı Şablonu
# =============================================================================
# Bu dosyayı kopyalayıp ".env" olarak adlandırın ve
# gerçek API anahtarlarınızı doldurun.
#
# UYARI: .env dosyasını asla GitHub'a göndermeyiniz!
#        .gitignore dosyasında ".env" zaten hariç tutulmuştur.
# =============================================================================

# Google Gemini API Anahtarı (Birincil LLM)
# Ücretsiz alın: https://aistudio.google.com → "Get API Key"
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Anahtarı (Yedek LLM — Llama 3)
# Ücretsiz alın: https://console.groq.com → "API Keys" → "Create API Key"
GROQ_API_KEY=your_groq_api_key_here

# FastAPI Backend URL'i (Streamlit için)
# Yerel geliştirmede varsayılan değeri kullanabilirsiniz
BACKEND_URL=http://localhost:8000
